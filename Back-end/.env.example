# ================================================
#  .env.example — Copy this to .env and fill in real values
#  NEVER commit actual .env to git
# ================================================

# Database
# Local development:
# DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/attendance_system"
# Docker compose:
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@db:5432/attendance_system"
# Neon (Production):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_MINIMUM_64_CHAR_RANDOM_STRING"
JWT_EXPIRES_IN="8h"

# Server
PORT=4000

# Frontend URL (used for CORS)
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379

# Email (Gmail App Password — NOT your main password)
EMAIL_SERVICE=gmail
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=نظام الحضور الإلكتروني
EMAIL_PASSWORD=your-gmail-app-password
